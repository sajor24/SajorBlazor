@page "/AddEmployee"
@rendermode InteractiveServer
@using Domain.Queries
@using Domain.Models
@using Domain.Commands
@inject ICreateCommand create
@inject IUpdateCommand update
@inject IDeleteCommand delete
@inject IGetAllEmployee getAll
@inject IReadEmployeeById read

<PageTitle>Employee Management</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h2>Employee Management</h2>
        </div>
    </div>
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <input class="form-control" placeholder="First Name" @bind="employee.FirstName" />
                </div>
                <div class="col-md-3">
                    <input class="form-control" placeholder="Last Name" @bind="employee.LastName" />
                </div>
                <div class="col-md-2">
                    <input class="form-control" placeholder="Age" @bind="employee.Age" />
                </div>
                <div class="col-md-3">
                    <input class="form-control" placeholder="Position" @bind="employee.Position" />
                </div>
                <div class="col-md-3 d-grid gap-2">
                    <button class="btn btn-success" @onclick="SaveEmployee">
                        @(isEditing ? "Save" : "Add Employee")
                    </button>
                    <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <input class="form-control" placeholder="Search by name or ID..." @bind="searchText" @bind:event="oninput" />
        </div>
    </div>

        <table class="table table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Age</th>
                    <th>Position</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in filteredEmployees)
                {
                    <tr>
                        <td>@emp.EmployeeId</td>
                        <td>@emp.FirstName</td>
                        <td>@emp.LastName</td>
                        <td>@emp.Age</td>
                        <td>@emp.Position</td>
                        <td>
                            <button class="btn btn-warning btn-sm"
                                    @onclick="() => ShowEditModal(emp)">
                                Edit
                            </button>

                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => Delete(emp.EmployeeId)">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    
</div>

@code {
    private List<Employee> employees = new();
    private Employee employee = new();
    private bool showForm = false;
    private bool isEditing = false;
    private string searchText = string.Empty;

    private IEnumerable<Employee> filteredEmployees => string.IsNullOrWhiteSpace(searchText)
        ? employees
        : employees.Where(e =>
            e.FirstName.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
           e.EmployeeId.ToString().Contains(searchText));

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployees();
    }

    async Task LoadEmployees()
    {
        var result = await getAll.ExecuteAsync();
        employees = result?.ToList() ?? new();
    }

    void ShowAddModal()
    {
        employee = new Employee();
        isEditing = false;
        showForm = true;
    }

    void ShowEditModal(Employee emp)
    {
        employee = new Employee
        {
            EmployeeId = emp.EmployeeId,
            FirstName = emp.FirstName,
            LastName = emp.LastName,
            Age = emp.Age,
            Position = emp.Position
        };
        isEditing = true;
        showForm = true;
    }

    async Task SaveEmployee()
    {
        if (isEditing)
        {
            await update.ExecuteAsync(employee);
        }
        else
        {
            await create.ExecuteAsync(employee);
        }

        employee = new Employee();
        isEditing = false;

        await LoadEmployees();
    }
    

    void CancelForm()
    {
        employee = new Employee();
        isEditing = false;
    }

    async Task Delete(int id)
    {
        var emp = new Employee { EmployeeId = id };
        await delete.ExecuteAsync(emp);
        await LoadEmployees();
    }
}